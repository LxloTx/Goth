                forestTrees.sort((a, b) => a.y - b.y);
                for (let i = 0; i < 80; i++) { fireflyPoints.push({ x: Math.random() * worldWidth, y: Math.random() * worldHeight, seed: Math.random() * Math.PI * 2 }); }
            }
            
            for (let i = 0; i < 30; i++) { fogPatches.push({ x: Math.random() * worldWidth, y: Math.random() * worldHeight, r: 120 + Math.random() * 180, seed: Math.random() * Math.PI * 2 }); }
        }

