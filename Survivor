        function updateLootHUD() {
            const inventoryDiv = document.getElementById('loot-inventory');
            if (!inventoryDiv) return;
            inventoryDiv.innerHTML = '';

            function getLootData(id) {
                const allArrays = [standardLootOptions, rareLootOptions, level2LootOptions, level2RareLootOptions, level3LootOptions, level3RareLootOptions];
                for (let arr of allArrays) {
                    let found = arr.find(l => l.id === id);
                    if (found) return found;
                }
                for (let key in evolvedLootOptions) {
                    if (evolvedLootOptions[key].id === id) return evolvedLootOptions[key];
                }
                for (let key in legendaryLootOptions) {
                    if (legendaryLootOptions[key].id === id) return legendaryLootOptions[key];
                }
                return null;
            }

            let displayItems = [];
            for (let baseId in lootCounts) {
                let currentId = baseId; let displayCount = lootCounts[baseId];

                if (unlockedEvolutions[baseId]) {
                    let evData = evolvedLootOptions[baseId];
                    if (evData) {
                        currentId = evData.id; displayCount = evolvedCounts[currentId] || 1;
                        if (unlockedLegendaries[currentId]) {
                            let lgData = legendaryLootOptions[currentId];
                            if (lgData) { currentId = lgData.id; displayCount = "★"; }
                        }
                    }
                }

                let data = getLootData(currentId);
                if (data) {
                    let icon = data.title.split(' ')[0];
                    displayItems.push({ icon, count: displayCount, color: data.iconColor });
                }
            }

            displayItems.forEach(item => {
                let box = document.createElement('div');
                box.className = 'loot-icon-box'; box.style.borderColor = item.color;
                
                let iconEl = document.createElement('span');
                iconEl.className = 'icon'; iconEl.innerText = item.icon;
                
                let countEl = document.createElement('span');
                countEl.className = 'count'; countEl.innerText = item.count;
                if (item.count === "★") countEl.style.color = "#f1c40f";
                
                box.appendChild(iconEl); box.appendChild(countEl); inventoryDiv.appendChild(box);
            });
        }

        function initEnvironmentMaps() {
