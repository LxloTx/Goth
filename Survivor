<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gothic Survivors: Expanded</title>
    <style>
        body {
            margin: 0;
            background-color: #050a06;
            color: #d4e0d0;
            font-family: 'Courier New', Courier, monospace;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            height: 100vh;
            overflow: hidden;
            user-select: none;
        }

        #hud {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            width: 800px;
            background: #111a12;
            padding: 14px 24px;
            border: 3px solid #000;
            box-shadow: 4px 4px 0px #030503;
            box-sizing: border-box;
            position: relative;
        }
        .hud-section {
            display: flex;
            flex-direction: column;
            margin-top: 4px;
        }
        .hud-label {
            font-size: 11px;
            font-weight: bold;
            color: #5c755e;
            letter-spacing: 1px;
            margin-bottom: 4px;
        }
        .hud-value {
            font-size: 18px;
            font-weight: bold;
            color: #ffffff;
            text-shadow: 2px 2px 0px #000;
        }
        .hp-container {
            width: 240px;
            display: flex;
            flex-direction: column;
            margin-top: 0;
        }
        
        .bar-bg {
            width: 100%;
            height: 14px;
            background-color: #241414;
            border: 2px solid #000;
            box-shadow: inset 2px 2px 0px rgba(0, 0, 0, 0.6);
            overflow: hidden;
            position: relative;
        }
        #shield-bar-box {
            height: 8px;
            background-color: #101f2b;
            margin-bottom: 4px;
            display: none;
        }
        #shield-bar-fill {
            width: 0%;
            height: 100%;
            background-color: #3498db;
        }
        #hp-bar-fill {
            width: 100%;
            height: 100%;
            background-color: #c0392b;
            transition: width 0.1s steps(10);
        }

        #loot-inventory {
            display: flex;
            flex-wrap: wrap;
            gap: 5px;
            margin-top: 8px;
            justify-content: center;
            width: 100%;
            min-height: 24px;
        }
        .loot-icon-box {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            width: 22px;
            height: 22px;
            background-color: #161c16;
            border: 1px solid #333;
            box-shadow: 2px 2px 0 rgba(0,0,0,0.8);
            position: relative;
        }
        .loot-icon-box .icon {
            font-size: 12px;
            line-height: 1;
        }
        .loot-icon-box .count {
            font-size: 9px;
            font-weight: bold;
            color: #ffffff;
            position: absolute;
            bottom: -4px;
            right: -4px;
            text-shadow: 1px 1px 0 #000;
            background: rgba(0,0,0,0.75);
            padding: 0 2px;
            border-radius: 2px;
            font-family: 'Courier New', monospace;
        }

        #loot-progress-container {
            position: absolute;
            bottom: 0;
            left: 0;
            width: 100%;
            height: 5px;
            background-color: #000;
        }
        #loot-progress-fill {
            width: 0%;
            height: 100%;
            background-color: #2ecc71;
            transition: width 0.2s ease;
        }

        canvas {
            border: 3px solid #000;
            border-top: none;
            box-shadow: 0 0 40px rgba(46, 204, 113, 0.15), 6px 6px 0px rgba(0,0,0,0.6);
            image-rendering: pixelated;
            cursor: pointer;
        }

        #hud { animation: hud-pulse 4s ease-in-out infinite; }

        @keyframes hud-pulse {
            0%, 100% { box-shadow: 4px 4px 0px #030503, 0 0 20px rgba(46,204,113,0.05); }
            50%       { box-shadow: 4px 4px 0px #030503, 0 0 30px rgba(46,204,113,0.15); }
        }

        #hp-bar-fill {
            background: linear-gradient(90deg, #8b0000, #c0392b, #e74c3c);
            box-shadow: 0 0 8px rgba(231, 76, 60, 0.6);
        }
        #shield-bar-fill {
            background: linear-gradient(90deg, #1a6ea0, #3498db, #5dade2);
            box-shadow: 0 0 8px rgba(52, 152, 219, 0.7);
        }
        #loot-progress-fill {
            background: linear-gradient(90deg, #1a8a4a, #2ecc71, #58d68d);
            box-shadow: 0 0 6px rgba(46, 204, 113, 0.8);
        }
    </style>
</head>
<body>

    <div id="hud">
        <div class="hud-section">
            <span class="hud-label">SURVIVED</span>
            <span id="timerText" class="hud-value">00:00</span>
        </div>
        <div class="hud-section hp-container">
            <span id="stageFloorLabel" class="hud-label" style="text-align: center; margin-bottom: 2px;">STAGE 1: WOODS</span>
            <div id="shield-bar-box" class="bar-bg">
                <div id="shield-bar-fill"></div>
            </div>
            <div class="bar-bg">
                <div id="hp-bar-fill"></div>
            </div>
            <div id="loot-inventory"></div>
        </div>
        <div class="hud-section" style="align-items: flex-end; margin-right: 60px;">
            <span class="hud-label">LVL <span id="lvlText">1</span> PURGED</span>
            <span id="scoreText" class="hud-value" style="color: #2ecc71;">0</span>
        </div>
        
        <div style="position: absolute; right: 20px; top: 10px; display: flex; flex-direction: column; align-items: flex-end; gap: 4px;">
            <div style="display: flex; align-items: center; gap: 6px;">
                <span style="font-size: 16px;">🪙</span><span id="coinText" style="color: #f1c40f; font-weight: bold; font-size: 14px;">0</span>
            </div>
            <div style="display: flex; align-items: center; gap: 6px;">
                <span style="font-size: 16px;">🎲</span><span id="diceText" style="color: #ecf0f1; font-weight: bold; font-size: 14px;">0</span>
            </div>
        </div>

        <div id="loot-progress-container">
            <div id="loot-progress-fill"></div>
        </div>
    </div>
    
    <canvas id="gameCanvas" width="800" height="600"></canvas>

    <script>
        const canvas = document.getElementById('gameCanvas');
        const ctx = canvas.getContext('2d');
        const hpFill = document.getElementById('hp-bar-fill');
        const shieldBox = document.getElementById('shield-bar-box');
        const shieldFill = document.getElementById('shield-bar-fill');
        const lootFill = document.getElementById('loot-progress-fill');
        const scoreEl = document.getElementById('scoreText');
        const timerEl = document.getElementById('timerText');
        const lvlEl = document.getElementById('lvlText');
        const coinEl = document.getElementById('coinText');
        const diceEl = document.getElementById('diceText');
        const floorLabelEl = document.getElementById('stageFloorLabel');

        let mouseX = 0, mouseY = 0;
        let hoveredCardIndex = -1;
        
        const distSq = (x1, y1, x2, y2) => (x2 - x1) * (x2 - x1) + (y2 - y1) * (y2 - y1);

        // --- PARTICLE SYSTEM ---
        let particles = [];
        function spawnParticles(x, y, count, color, speed, life, size) {
            for (let i = 0; i < count; i++) {
                let angle = Math.random() * Math.PI * 2;
                let spd = speed * (0.5 + Math.random() * 0.8);
                particles.push({ x, y, vx: Math.cos(angle)*spd, vy: Math.sin(angle)*spd - 0.5, color, life, maxLife: life, size: size * (0.5 + Math.random()), alpha: 1 });
            }
        }
        function updateParticles() {
            for (let i = particles.length - 1; i >= 0; i--) {
                let p = particles[i];
                p.x += p.vx; p.y += p.vy; p.vy += 0.06;
                p.vx *= 0.96; p.vy *= 0.96;
                p.life--;
                p.alpha = p.life / p.maxLife;
                if (p.life <= 0) particles.splice(i, 1);
            }
        }
        function drawParticles() {
            particles.forEach(p => {
                let sx = p.x - camera.x, sy = p.y - camera.y;
                if (sx < -20 || sx > canvas.width+20 || sy < -20 || sy > canvas.height+20) return;
                ctx.save(); ctx.globalAlpha = p.alpha; ctx.fillStyle = p.color; ctx.beginPath(); ctx.arc(sx, sy, p.size, 0, Math.PI*2); ctx.fill(); ctx.restore();
            });
        }

        let screenShake = { x: 0, y: 0, intensity: 0 };
        function triggerShake(intensity) { screenShake.intensity = Math.max(screenShake.intensity, intensity); }
        function updateScreenShake() {
            if (screenShake.intensity > 0.2) {
                screenShake.x = (Math.random()-0.5)*screenShake.intensity; screenShake.y = (Math.random()-0.5)*screenShake.intensity; screenShake.intensity *= 0.75;
            } else { screenShake.x = 0; screenShake.y = 0; screenShake.intensity = 0; }
        }

        let hitFlashAlpha = 0;

        // --- MAP & CAMERA ENGINE ---
        let worldWidth = 3200; 
        let worldHeight = 2400;
        let camera = { x: 0, y: 0 };
        let level3CameraY = 0;

        // --- ADVANCED AUDIO ENGINE ---
        let audioCtx = null;
        let masterGain = null;
        let masterVolume = 0.5;
        let musicInterval = null;
        let musicStep = 0; 
        let currentTheme = 'MAIN_MENU'; 
        let isAudioInitialized = false;

        const TRACKS = {
            'MAIN_MENU': { tempo: 0.12, leadType: 'square', bassType: 'sawtooth', filterFreq: 1500, seq: [0, 1, 0, 2, 3, 4, 3, 5], patterns: [ { b: [33,0,33,0,45,0,33,0, 33,0,33,0,45,43,41,39], l: [57,0,60,0,64,0,69,67, 64,0,60,0,57,0,60,64] }, { b: [33,0,33,0,45,0,33,0, 33,0,33,0,48,47,45,43], l: [69,0,67,0,64,0,60,57, 55,0,57,0,60,0,64,67] }, { b: [29,0,29,0,41,0,29,0, 29,0,29,0,41,0,43,0], l: [53,0,57,0,60,0,65,0, 60,0,57,0,53,0,57,60] }, { b: [38,38,38,38,50,50,50,50, 38,38,38,38,48,47,45,43], l: [62,0,65,0,69,0,74,0, 69,0,65,0,62,0,65,69] }, { b: [36,36,36,36,48,48,48,48, 36,36,36,36,45,45,45,45], l: [60,0,64,0,67,0,72,0, 67,0,64,0,60,0,64,67] }, { b: [31,0,31,0,31,0,31,0, 31,31,31,31,31,31,31,31], l: [67,67,67,67,67,67,67,67, 79,79,79,79,79,79,79,79] } ] },
            'LEVEL_1': { tempo: 0.13, leadType: 'triangle', bassType: 'sawtooth', filterFreq: 800, seq: [0, 1, 0, 2, 0, 1, 3, 4], patterns: [ { b: [45,0,57,0,45,0,57,0, 41,0,53,0,41,0,53,0], l: [57,0,60,64, 67,69,67,0, 53,0,57,60, 65,67,65,0] }, { b: [43,0,55,0,43,0,55,0, 40,0,52,0,40,0,52,0], l: [55,0,59,62, 67,69,67,0, 52,0,56,59, 64,62,59,0] }, { b: [38,0,50,0,38,0,50,0, 36,0,48,0,36,0,48,0], l: [62,0,65,69, 74,0,74,0, 60,0,64,67, 72,0,72,0] }, { b: [45,45,45,45, 41,41,41,41, 43,43,43,43, 40,40,40,40], l: [69,0,67,0, 65,0,64,0, 62,0,60,0, 59,0,57,0] }, { b: [33,33,33,33, 33,33,33,33, 33,0,0,0, 0,0,0,0], l: [57,57,60,60, 64,64,67,67, 69,0,0,0, 0,0,0,0] } ] },
            'LEVEL_2': { tempo: 0.16, leadType: 'square', bassType: 'sine', filterFreq: 300, seq: [0, 1, 0, 2, 3, 4], patterns: [ { b: [36,0,37,0,36,0,33,34, 36,0,43,42,36,0,0,0], l: [60,0,61,0,66,0,65,0, 72,0,71,0,59,0,60,0] }, { b: [36,0,37,0,36,0,33,34, 36,0,31,32,36,0,0,0], l: [61,0,67,0,73,0,72,0, 60,0,0,0, 0,0,0,0] }, { b: [32,0,33,0,32,0,29,30, 32,0,39,38,32,0,0,0], l: [56,0,57,0,62,0,61,0, 68,0,67,0,55,0,56,0] }, { b: [40,0,41,0,40,0,37,38, 40,0,47,46,40,0,0,0], l: [64,0,65,0,70,0,69,0, 76,0,75,0,63,0,64,0] }, { b: [36,36,36,36, 37,37,37,37, 38,38,38,38, 39,39,39,39], l: [60,60,60,60, 61,61,61,61, 62,62,62,62, 63,63,63,63] } ] },
            'BATTLE_LVL3': { tempo: 0.08, leadType: 'sawtooth', bassType: 'sawtooth', filterFreq: 1800, seq: [0, 0, 1, 2, 0, 0, 3, 4], patterns: [ { b: [36,36,36,36,48,48,48,48, 36,36,36,36,43,43,43,43], l: [60,0,62,63,67,0,72,71, 67,0,63,0,60,62,63,67] }, { b: [31,31,31,31,43,43,43,43, 31,31,31,31,38,38,38,38], l: [55,0,57,58,62,0,67,66, 62,0,58,0,55,57,58,62] }, { b: [29,29,29,29,41,41,41,41, 29,29,29,29,36,36,36,36], l: [53,0,55,56,60,0,65,64, 60,0,56,0,53,55,56,60] }, { b: [40,40,40,40,40,40,40,40, 41,41,41,41,41,41,41,41], l: [72,72,72,72,72,72,72,72, 73,73,73,73,73,73,73,73] }, { b: [43,43,43,43,43,43,43,43, 45,45,45,45,47,47,47,47], l: [75,75,75,75,75,75,75,75, 77,77,77,77,79,79,79,79] } ] },
            'BOSS': { tempo: 0.09, leadType: 'square', bassType: 'sawtooth', filterFreq: 2000, seq: [0, 1, 0, 2], patterns: [ { b: [33,33,45,33, 33,45,36,38, 33,33,45,33, 33,48,47,45], l: [45,0,57,56, 53,0,52,0, 45,0,60,59, 57,0,62,64] }, { b: [29,29,41,29, 29,41,32,34, 29,29,41,29, 29,44,43,41], l: [41,0,53,52, 49,0,48,0, 41,0,56,55, 53,0,58,60] }, { b: [36,36,48,36, 36,48,39,41, 36,36,48,36, 36,51,50,48], l: [48,0,60,59, 56,0,55,0, 48,0,63,62, 60,0,65,67] } ] },
            'MINI_BOSS': { tempo: 0.07, leadType: 'sawtooth', bassType: 'sawtooth', filterFreq: 2400, seq: [0, 1], patterns: [ { b: [38,38,50,38, 38,50,38,50, 38,38,50,38, 41,41,40,40], l: [62,0,65,0, 69,0,65,0, 62,0,65,0, 74,0,73,0] }, { b: [36,36,48,36, 36,48,36,48, 36,36,48,36, 39,39,38,38], l: [60,0,63,0, 67,0,63,0, 60,0,63,0, 72,0,71,0] } ] },
            'FROG_SHOP': { tempo: 0.16, leadType: 'triangle', bassType: 'sine', filterFreq: 600, seq: [0, 1], patterns: [ { b: [41,0,41,0,48,0,48,0, 41,0,41,0,48,0,48,0], l: [65,0,68,0,65,0,72,0, 65,0,68,0,77,0,72,0] }, { b: [36,0,36,0,43,0,43,0, 36,0,36,0,43,0,43,0], l: [60,0,63,0,60,0,67,0, 60,0,63,0,72,0,67,0] } ] }
        };

        function midiToFreq(note) { return 440 * Math.pow(2, (note - 69) / 12); }

        function initAudio() {
            if (!audioCtx) {
                audioCtx = new (window.AudioContext || window.webkitAudioContext)();
                masterGain = audioCtx.createGain(); masterGain.gain.value = masterVolume; masterGain.connect(audioCtx.destination);
                isAudioInitialized = true; startSequencer();
            } else if (audioCtx.state === 'suspended') { audioCtx.resume(); }
        }

        function startSequencer() {
            if (musicInterval) clearInterval(musicInterval);
            let trackData = TRACKS[currentTheme];
            musicInterval = setInterval(() => {
                trackData = TRACKS[currentTheme];
                if (gameState === 'GAMEOVER' || gameState === 'PRE_START' || gameState === 'PAUSED') return;

                const now = audioCtx.currentTime;
                let totalSteps = trackData.seq.length * 16; let currentStepInSong = musicStep % totalSteps;
                let currentPatternIndex = Math.floor(currentStepInSong / 16); let currentStepInPattern = currentStepInSong % 16;
                let activePatternId = trackData.seq[currentPatternIndex]; let activePattern = trackData.patterns[activePatternId];

                let bassNote = activePattern.b[currentStepInPattern]; let leadNote = activePattern.l[currentStepInPattern];

                if (bassNote > 0) {
                    let oscB = audioCtx.createOscillator(); let gainB = audioCtx.createGain();
                    oscB.type = trackData.bassType; oscB.frequency.setValueAtTime(midiToFreq(bassNote - 12), now);
                    let filterB = audioCtx.createBiquadFilter(); filterB.type = 'lowpass'; filterB.frequency.setValueAtTime(trackData.filterFreq, now);
                    gainB.gain.setValueAtTime(currentTheme === 'BOSS' || currentTheme === 'MINI_BOSS' ? 0.12 : 0.08, now); gainB.gain.exponentialRampToValueAtTime(0.001, now + trackData.tempo * 0.9);
                    oscB.connect(filterB); filterB.connect(gainB); gainB.connect(masterGain); oscB.start(now); oscB.stop(now + trackData.tempo);
                }

                if (leadNote > 0) {
                    let oscL = audioCtx.createOscillator(); let gainL = audioCtx.createGain();
                    oscL.type = trackData.leadType; oscL.frequency.setValueAtTime(midiToFreq(leadNote + 12), now); 
                    let filterL = audioCtx.createBiquadFilter(); filterL.type = (currentTheme === 'LEVEL_2') ? 'bandpass' : 'lowpass'; filterL.frequency.setValueAtTime(trackData.filterFreq * 1.5, now);
                    gainL.gain.setValueAtTime((currentTheme === 'LEVEL_2') ? 0.02 : 0.04, now); gainL.gain.exponentialRampToValueAtTime(0.001, now + (trackData.tempo * 1.5));
                    oscL.connect(filterL); filterL.connect(gainL); gainL.connect(masterGain); oscL.start(now); oscL.stop(now + (trackData.tempo * 2));
                }
                musicStep++;
            }, trackData.tempo * 1000);
        }

        // --- UI SFX ---
        function playHoverSFX() {
            if (!audioCtx || masterVolume === 0) return;
            let osc = audioCtx.createOscillator(); let gain = audioCtx.createGain();
            osc.type = 'sine'; osc.frequency.setValueAtTime(600, audioCtx.currentTime); osc.frequency.exponentialRampToValueAtTime(800, audioCtx.currentTime + 0.05);
            gain.gain.setValueAtTime(0.05, audioCtx.currentTime); gain.gain.exponentialRampToValueAtTime(0.001, audioCtx.currentTime + 0.05);
            osc.connect(gain); gain.connect(masterGain); osc.start(); osc.stop(audioCtx.currentTime + 0.05);
        }

        function playRareLootSFX() {
            if (!audioCtx || masterVolume === 0) return;
            const now = audioCtx.currentTime;
            [440, 554.37, 659.25, 880].forEach((freq, i) => { 
                let osc = audioCtx.createOscillator(); let gain = audioCtx.createGain();
                osc.type = 'triangle'; osc.frequency.setValueAtTime(freq, now + i*0.06);
                gain.gain.setValueAtTime(0.15, now + i*0.06); gain.gain.exponentialRampToValueAtTime(0.001, now + 0.5 + i*0.06);
                osc.connect(gain); gain.connect(masterGain); osc.start(now + i*0.06); osc.stop(now + 0.5 + i*0.06);
            });
        }

        function playDiceSFX() {
            if (!audioCtx || masterVolume === 0) return;
            const now = audioCtx.currentTime;
            for(let i=0; i<3; i++) {
                let osc = audioCtx.createOscillator(); let gain = audioCtx.createGain();
                osc.type = 'square'; osc.frequency.setValueAtTime(300 + Math.random()*200, now + i*0.08);
                gain.gain.setValueAtTime(0.1, now + i*0.08); gain.gain.exponentialRampToValueAtTime(0.001, now + 0.05 + i*0.08);
                osc.connect(gain); gain.connect(masterGain); osc.start(now + i*0.08); osc.stop(now + 0.05 + i*0.08);
            }
        }

        function playCustomHitSFX(type) {
            if (!audioCtx || masterVolume === 0) return;
            const now = audioCtx.currentTime;
            let osc = audioCtx.createOscillator(); let gain = audioCtx.createGain(); osc.connect(gain); gain.connect(masterGain);

            if (type === 'skeleton') { osc.type = 'square'; osc.frequency.setValueAtTime(1200, now); osc.frequency.exponentialRampToValueAtTime(100, now + 0.04); let filter = audioCtx.createBiquadFilter(); filter.type = 'bandpass'; filter.frequency.setValueAtTime(1500, now); osc.disconnect(); osc.connect(filter); filter.connect(gain); gain.gain.setValueAtTime(0.4, now); gain.gain.exponentialRampToValueAtTime(0.01, now + 0.04); osc.start(now); osc.stop(now + 0.04); }
            else if (type === 'cursed_soldier' || type === 'elite_cursed_soldier') { osc.type = 'sawtooth'; osc.frequency.setValueAtTime(600, now); osc.frequency.exponentialRampToValueAtTime(200, now + 0.15); gain.gain.setValueAtTime(0.2, now); gain.gain.exponentialRampToValueAtTime(0.01, now + 0.15); osc.start(now); osc.stop(now + 0.15); }
            else if (type === 'bone_warrior' || type === 'elite_bone_warrior') { osc.type = 'triangle'; osc.frequency.setValueAtTime(800, now); osc.frequency.exponentialRampToValueAtTime(100, now + 0.05); gain.gain.setValueAtTime(0.3, now); gain.gain.exponentialRampToValueAtTime(0.01, now + 0.05); osc.start(now); osc.stop(now + 0.05); } 
