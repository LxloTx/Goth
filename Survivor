            let speedX = (dx * player.speed) + player.kbX;
            let speedY = (dy * player.speed) + player.kbY;

            if (dx !== 0 && dy !== 0) { speedX = (dx * 0.7071 * player.speed) + player.kbX; speedY = (dy * 0.7071 * player.speed) + player.kbY; }
            
            let nextX = player.x + speedX;
            let nextY = player.y + speedY;
            let collides = false;
            
            if (currentLevel === 2) {
                for(let p of brokenPillars) { if (distSq(nextX, nextY, p.x, p.y) < (player.radius + p.radius) * (player.radius + p.radius)) { collides = true; break; } }
