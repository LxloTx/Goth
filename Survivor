        window.addEventListener('keydown', e => { 
            let key = e.key.toLowerCase();
            if (key === 'z') {
                if (gameState === 'PLAYING') { gameState = 'PAUSED'; pauseMenuOpenTime = Date.now(); } 
                else if (gameState === 'PAUSED') { gameState = 'PLAYING'; pausedTimeAcc += (Date.now() - pauseMenuOpenTime); keys = {}; }
                else if (gameState === 'SAVE_MENU') { gameState = 'PAUSED'; }
                else if (gameState === 'LOAD_MENU') { gameState = 'START'; }
            }
            if(gameState === 'PLAYING' && !lootSelectionActive) keys[key] = true; 
        });
        window.addEventListener('keyup', e => { keys[e.key.toLowerCase()] = false; });
        
        canvas.addEventListener('mousemove', e => {
            const rect = canvas.getBoundingClientRect(); mouseX = e.clientX - rect.left; mouseY = e.clientY - rect.top;

            if (gameState === 'PLAYING' && lootSelectionActive) {
                let newHover = -1;
                for (let i = 0; i < lootCards.length; i++) {
                    let card = lootCards[i];
                    if (mouseX >= card.x && mouseX <= card.x + card.w && mouseY >= card.y && mouseY <= card.y + card.h) { newHover = i; break; }
                }
                let rerollBtn = { x: canvas.width/2 - 90, y: 530, w: 180, h: 45 };
                if (mouseX >= rerollBtn.x && mouseX <= rerollBtn.x + rerollBtn.w && mouseY >= rerollBtn.y && mouseY <= rerollBtn.y + rerollBtn.h) { newHover = 99; }

                if (newHover !== hoveredCardIndex) {
                    if (newHover !== -1) playHoverSFX();
                    hoveredCardIndex = newHover;
                }
            }
        });

        canvas.addEventListener('click', e => {
            if (gameState === 'PRE_START') { initAudio(); gameState = 'START'; return; }
            if (gameState === 'START') { 
                if (mouseY >= 360 && mouseY <= 400 && mouseX >= canvas.width/2 - 100 && mouseX <= canvas.width/2 + 100) { gameState = 'LOAD_MENU'; saveState = 'SELECT_SLOT'; playHoverSFX(); return; }
                startNewMatch(); return; 
            }
            if (gameState === 'GAMEOVER' || gameState === 'VICTORY') { startNewMatch(); return; }
            if (gameState === 'LEVEL_INTRO') { gameState = 'PLAYING'; return; }
            
            if (gameState === 'SAVE_MENU' || gameState === 'LOAD_MENU') {
                if (saveState === 'SAVING') return; 
                let midX = canvas.width / 2;
                if (saveState === 'SELECT_SLOT') {
                    for(let i=0; i<3; i++) {
                        let sy = 150 + i * 110;
                        if (mouseX >= midX - 200 && mouseX <= midX + 200 && mouseY >= sy && mouseY <= sy + 90) {
                            selectedSlot = i;
                            if (gameState === 'LOAD_MENU' && !saveSlots[i]) return; // Block loading empty slot
                            saveState = 'CONFIRM_SAVE'; playHoverSFX();
                        }
