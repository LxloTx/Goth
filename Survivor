                    if (mouseX >= midX - 80 && mouseX <= midX - 40) { masterVolume = Math.max(0, masterVolume - 0.1); if (masterGain) masterGain.gain.value = masterVolume; }
                    if (mouseX >= midX + 40 && mouseX <= midX + 80) { masterVolume = Math.min(1, masterVolume + 0.1); if (masterGain) masterGain.gain.value = masterVolume; }
