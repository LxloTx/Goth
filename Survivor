                        px = Math.random() * worldWidth;
                        py = Math.random() * worldHeight;
                    } while (distSq(px, py, worldWidth / 2, worldHeight / 2) < 40000);

                    brokenPillars.push({ x: px, y: py, radius: 20 + Math.random() * 15, type: Math.floor(Math.random() * 3) });
                }
                for (let i = 0; i < 150; i++) {
                    level2FloorTiles.push({ x: Math.random() * worldWidth, y: Math.random() * worldHeight, type: Math.random() > 0.6 ? 'grass' : 'broken', size: 15 + Math.random() * 25 });
                }
                for (let i = 0; i < 70; i++) { 
                    castlePillars.push({ x: Math.random() * worldWidth, y: Math.random() * worldHeight, w: 35 + Math.random() * 20, h: 70 + Math.random() * 40, glow: Math.random() < 0.3, seed: Math.random() * Math.PI * 2 }); 
                }
                castlePillars.sort((a, b) => a.y - b.y);
            }
            
            if (currentLevel === 1) {
                for (let i = 0; i < 140; i++) { forestBeds.push({ x: Math.random() * worldWidth, y: Math.random() * worldHeight, w: 50 + Math.random() * 80, h: 25 + Math.random() * 40, color: Math.random() > 0.5 ? '#0e1c0f' : '#142616' }); }
