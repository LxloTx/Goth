                    if (mouseY >= 520 && mouseY <= 560 && mouseX >= midX - 100 && mouseX <= midX + 100) { gameState = gameState === 'SAVE_MENU' ? 'PAUSED' : 'START'; playHoverSFX(); }
                } else if (saveState === 'CONFIRM_SAVE') {
                    if (mouseY >= 350 && mouseY <= 400) {
