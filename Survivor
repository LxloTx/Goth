                } else {
                    ctx.fillStyle = '#7f8c8d'; ctx.beginPath(); ctx.moveTo(8, -2); ctx.lineTo(12, 0); ctx.lineTo(8, 2); ctx.fill();
                    ctx.fillStyle = '#c0392b'; ctx.beginPath(); ctx.moveTo(-8, -3); ctx.lineTo(-12, -4); ctx.lineTo(-10, 0); ctx.lineTo(-12, 4); ctx.lineTo(-8, 3); ctx.fill();
                }
                ctx.restore(); return;
            }

            let len = (shopInventory.longswordPurchased || shopInventory.holyBladePurchased || player.hasTitanBlade || player.hasWarbringer ? 35 : 20) * (player.holyBladeLevel > 0 ? 1.5 : 1.0);
            let w = (shopInventory.longswordPurchased || shopInventory.holyBladePurchased || player.hasTitanBlade ? 6 : 4);
            let wType = getWeaponType(isHero);
            
            let swordColor = '#bdc3c7';
            if (isHero) {
                if (player.hasBloodGod || player.hasLordOfBlood) swordColor = '#e74c3c';
                else if (player.hasDivineJudgement || player.hasHolyLance || shopInventory.holyBladePurchased) swordColor = '#ffd700';
