        function drawFlyingWeapon(x, y, angle, isHero, projType) {
            let sx = x - camera.x, sy = y - camera.y; 
            ctx.save(); ctx.translate(sx, sy); ctx.rotate(angle);
            
            if (projType === 'arrow' || projType === 'lightning_arrow') {
                ctx.fillStyle = '#bdc3c7'; ctx.fillRect(-8, -1, 16, 2);
