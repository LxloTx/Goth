                ctx.fillStyle = '#0a0a0a';
                ctx.fillRect(-35, -35, 70, 70);
                
                ctx.strokeStyle = card.lootData.iconColor;
                ctx.lineWidth = 2;
                ctx.strokeRect(-35, -35, 70, 70);
                
                ctx.fillStyle = card.lootData.iconColor;
                ctx.fillRect(-37, -37, 8, 2); ctx.fillRect(-37, -37, 2, 8);
                ctx.fillRect(29, -37, 8, 2);  ctx.fillRect(35, -37, 2, 8);
                ctx.fillRect(-37, 35, 8, 2);  ctx.fillRect(-37, 29, 2, 8);
                ctx.fillRect(29, 35, 8, 2);   ctx.fillRect(35, 29, 2, 8);

                ctx.shadowBlur = 0; ctx.font = '40px Arial'; ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
                ctx.fillText(iconStr, 0, 5);
                ctx.restore();

                let titleY = isLegendary || isEvolved ? 145 : 135;
                ctx.fillStyle = card.lootData.iconColor; ctx.font = 'bold 17px "Courier New"'; ctx.textAlign = 'center';
                ctx.fillText(cleanTitle, card.w/2, titleY);

                let statY = titleY + 20;
                ctx.fillStyle = 'rgba(255, 255, 255, 0.05)';
                ctx.fillRect(15, statY, card.w - 30, 30);
                ctx.strokeStyle = 'rgba(255, 255, 255, 0.15)';
                ctx.lineWidth = 1;
                ctx.strokeRect(15, statY, card.w - 30, 30);
                
                ctx.fillStyle = '#00e5ff'; ctx.font = 'bold 12px "Courier New"';
                ctx.fillText(card.lootData.stats || "UPGRADE", card.w/2, statY + 19);

                let descY = statY + 45;
                ctx.fillStyle = '#b2bec3'; ctx.font = '13px "Courier New"';
                let words = card.lootData.desc.split(' '), line = '', y = descY;
                for(let n = 0; n < words.length; n++) {
                    let testLine = line + words[n] + ' ';
                    if (ctx.measureText(testLine).width > card.w - 24 && n > 0) { ctx.fillText(line, card.w/2, y); line = words[n] + ' '; y += 18; }
                    else { line = testLine; }
                }
                ctx.fillText(line, card.w/2, y);

                // --- PIP COUNTER FIXED TO 12 ---
                if (!isLegendary) {
                    let baseId  = card.lootData._evolvedFromId || card.lootData.id;
                    let evId    = card.lootData._evolvedFromId ? card.lootData.id : null;
                    let maxCount = 12;
                    let totalCount = isEvolved ? 4 + (evolvedCounts[evId] || 0) : (lootCounts[baseId] || 0);
                    
                    if (totalCount > 0 || isEvolved) {
                        ctx.font = '12px "Courier New"'; ctx.textAlign = 'center';
                        ctx.fillStyle = totalCount >= 4 ? (isEvolved ? '#b44dff' : '#f1c40f') : '#7f8c8d';
                        let dots = ''; for (let d = 0; d < maxCount; d++) { dots += d < totalCount ? '●' : '○'; }
                        let label = totalCount >= 12 ? 'MAXED' : (totalCount === 4 && !isEvolved ? 'READY TO EVOLVE' : `LVL ${totalCount + 1}`);
                        ctx.fillText(`${dots}`, card.w/2, card.h - 22);
                        ctx.fillText(`${label}`, card.w/2, card.h - 8);
                    }
                } else {
                    ctx.fillStyle = '#ffd700'; ctx.font = 'bold 12px "Courier New"'; ctx.textAlign = 'center';
                    let dots = '●●●●●●●●●●●●';
                    ctx.fillText(`${dots}`, card.w/2, card.h - 22);
                    ctx.fillText('MAXIMUM POWER', card.w/2, card.h - 8);
                }

                ctx.restore();
            });

            let rerollBtn = { x: canvas.width/2 - 90, y: 530, w: 180, h: 45 };
            let hoverReroll = hoveredCardIndex === 99;
            
            ctx.fillStyle = player.rerolls > 0 ? (hoverReroll ? '#2980b9' : '#3498db') : '#1a1a1a';
            ctx.fillRect(rerollBtn.x, rerollBtn.y, rerollBtn.w, rerollBtn.h);
            
            ctx.strokeStyle = player.rerolls > 0 ? '#ecf0f1' : '#333';
            ctx.lineWidth = 2; 
            ctx.strokeRect(rerollBtn.x, rerollBtn.y, rerollBtn.w, rerollBtn.h);
            
            ctx.fillStyle = player.rerolls > 0 ? '#fff' : '#777';
            ctx.font = 'bold 18px "Courier New"'; 
            ctx.textAlign = 'center';
            ctx.fillText(`REROLL (🎲 ${player.rerolls})`, canvas.width/2, rerollBtn.y + 28);
        }

        function gameLoop() {
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            drawLevelBackground();
            
            if (gameState === 'PLAYING' || gameState === 'LEVEL_INTRO' || gameState === 'GAMEOVER' || gameState === 'PAUSED') {
                coins.forEach(drawCoinAsset); chickens.forEach(drawChicken); friendlySkeletons.forEach(drawFriendlySkeleton); enemies.forEach(drawEnemyAnatomy); javelins.forEach(drawJavelinAsset); enemyProjectiles.forEach(drawProjectileProjectile); bullets.forEach(b => drawFlyingWeapon(b.x, b.y, b.angle, b.isHero, b.projectileType)); firebolts.forEach(drawFirebolt); iceBolts.forEach(drawIceBolt);
                if (player.hp > 0) { if (player.whirlwindLevel > 0) drawWhirlwindShield(player.x, player.y, player.whirlwindLevel); drawKnightCharacter(player.x, player.y, player.radius, player.isMoving); }
                drawStaticSceneryAssets(); drawWorldBorders(); drawParticles();
            }

            if (gameState === 'SHOP' || gameState === 'SHOP_LVL2') { drawShopInterface(); }
            if (lootSelectionActive) { drawLootMenu(); }
            if (hitFlashAlpha > 0) { ctx.fillStyle = `rgba(231, 76, 60, ${hitFlashAlpha})`; ctx.fillRect(0, 0, canvas.width, canvas.height); hitFlashAlpha -= 0.05; }

            // PAUSE MENU RENDERING
            if (gameState === 'PAUSED') {
                ctx.fillStyle = 'rgba(0, 0, 0, 0.7)'; ctx.fillRect(0, 0, canvas.width, canvas.height); ctx.fillStyle = '#f1c40f'; ctx.font = 'bold 40px "Courier New"'; ctx.textAlign = 'center'; ctx.fillText("PAUSED", canvas.width/2, 200);
                ctx.fillStyle = '#fff'; ctx.font = '20px "Courier New"'; ctx.fillText("MASTER VOLUME", canvas.width/2, 280);
                ctx.fillStyle = '#e74c3c'; ctx.fillRect(canvas.width/2 - 80, 310, 40, 40); ctx.fillStyle = '#2ecc71'; ctx.fillRect(canvas.width/2 + 40, 310, 40, 40);
                ctx.fillStyle = '#fff'; ctx.font = 'bold 24px "Courier New"'; ctx.fillText("-", canvas.width/2 - 60, 338); ctx.fillText("+", canvas.width/2 + 60, 338); ctx.fillText(Math.round(masterVolume * 100) + "%", canvas.width/2, 338);
                
                // New Save Button
                ctx.fillStyle = '#2c3e50'; ctx.fillRect(canvas.width/2 - 100, 440, 200, 40); ctx.strokeStyle = '#f1c40f'; ctx.lineWidth = 2; ctx.strokeRect(canvas.width/2 - 100, 440, 200, 40);
                ctx.fillStyle = '#f1c40f'; ctx.font = 'bold 18px "Courier New"'; ctx.fillText("SAVE GAME", canvas.width/2, 466);
                ctx.fillStyle = '#7f8c8d'; ctx.font = '16px "Courier New"'; ctx.fillText("Press 'Z' to Resume", canvas.width/2, 520);
            }

            // NEW SAVE AND LOAD MENUS
            if (gameState === 'SAVE_MENU' || gameState === 'LOAD_MENU') {
                ctx.fillStyle = 'rgba(0, 0, 0, 0.9)'; ctx.fillRect(0, 0, canvas.width, canvas.height);
                ctx.fillStyle = '#f1c40f'; ctx.font = 'bold 36px "Courier New"'; ctx.textAlign = 'center'; 
                ctx.fillText(gameState === 'SAVE_MENU' ? "SAVE GAME" : "LOAD GAME", canvas.width/2, 80);

                let midX = canvas.width / 2;
                if (saveState === 'SELECT_SLOT') {
                    for(let i=0; i<3; i++) {
                        let sy = 150 + i * 110;
                        ctx.fillStyle = '#1c2833'; ctx.fillRect(midX - 200, sy, 400, 90);
                        ctx.strokeStyle = '#34495e'; ctx.lineWidth = 2; ctx.strokeRect(midX - 200, sy, 400, 90);
                        ctx.fillStyle = '#fff'; ctx.font = 'bold 20px "Courier New"'; ctx.textAlign = 'left';
                        ctx.fillText(`FILE ${i + 1}`, midX - 180, sy + 30);
                        
                        if (saveSlots[i]) {
                            let s = saveSlots[i];
                            let timeStr = `${Math.floor(s.totalSeconds / 60).toString().padStart(2, '0')}:${(s.totalSeconds % 60).toString().padStart(2, '0')}`;
                            ctx.fillStyle = '#2ecc71'; ctx.font = '14px "Courier New"';
                            ctx.fillText(`STAGE: ${s.currentLevel} | LVL: ${s.player.level} | COINS: ${s.player.coinsCollected}`, midX - 180, sy + 55);
                            ctx.fillStyle = '#bdc3c7';
                            ctx.fillText(`SCORE: ${s.score} | TIME: ${timeStr}`, midX - 180, sy + 75);
                        } else {
                            ctx.fillStyle = '#7f8c8d'; ctx.font = 'italic 16px "Courier New"'; ctx.fillText("EMPTY DATA", midX - 180, sy + 60);
                        }
                    }
                    ctx.fillStyle = '#e74c3c'; ctx.fillRect(midX - 100, 520, 200, 40); ctx.fillStyle = '#fff'; ctx.textAlign = 'center'; ctx.fillText("BACK", midX, 546);
                } else if (saveState === 'CONFIRM_SAVE') {
                    ctx.fillStyle = '#fff'; ctx.font = 'bold 24px "Courier New"'; ctx.textAlign = 'center';
                    ctx.fillText(`ARE YOU SURE YOU WANT TO ${gameState === 'SAVE_MENU' ? 'OVERWRITE' : 'LOAD'} FILE ${selectedSlot + 1}?`, midX, 280);
                    ctx.fillStyle = '#2ecc71'; ctx.fillRect(midX - 120, 350, 100, 50); ctx.fillStyle = '#000'; ctx.fillText("YES", midX - 70, 382);
                    ctx.fillStyle = '#e74c3c'; ctx.fillRect(midX + 20, 350, 100, 50); ctx.fillStyle = '#fff'; ctx.fillText("NO", midX + 70, 382);
                } else if (saveState === 'SAVING') {
                    ctx.fillStyle = '#fff'; ctx.font = 'bold 24px "Courier New"'; ctx.textAlign = 'center'; ctx.fillText("SAVING...", midX, 280);
                    ctx.fillStyle = '#e74c3c'; ctx.font = 'bold 18px "Courier New"';
                    let flicker = Math.sin(Date.now() * 0.01) > 0 ? "DO NOT TURN OFF POWER!" : "";
                    ctx.fillText(flicker, midX, 420);
                    
                    // Spinning Memory Card Sprite Animation
                    ctx.save(); ctx.translate(midX, 350); ctx.scale(Math.sin(Date.now() * 0.005), 1);
                    ctx.fillStyle = '#7f8c8d'; ctx.fillRect(-20, -25, 40, 50); ctx.fillStyle = '#bdc3c7'; ctx.fillRect(-15, -10, 30, 30);
                    ctx.fillStyle = '#f1c40f'; ctx.fillRect(-15, -25, 5, 10); ctx.fillRect(-5, -25, 5, 10); ctx.fillRect(5, -25, 5, 10);
                    ctx.restore();
                    
                    if (Date.now() - savingTimer > 2000) { saveGame(selectedSlot); saveState = 'SELECT_SLOT'; }
                }
            }

            if (gameState === 'GAMEOVER') {
                ctx.fillStyle = 'rgba(0, 0, 0, 0.8)'; ctx.fillRect(0, 0, canvas.width, canvas.height); ctx.fillStyle = '#e74c3c'; ctx.font = 'bold 48px "Courier New"'; ctx.textAlign = 'center'; ctx.fillText("YOU DIED", canvas.width/2, canvas.height/2 - 40); ctx.fillStyle = '#fff'; ctx.font = '24px "Courier New"'; ctx.fillText(`FINAL SCORE: ${score}`, canvas.width/2, canvas.height/2 + 20);
                if (isNewHighScore) { ctx.fillStyle = '#f1c40f'; ctx.fillText(`NEW HIGH SCORE!`, canvas.width/2, canvas.height/2 + 60); }
                ctx.fillStyle = '#7f8c8d'; ctx.font = '16px "Courier New"'; ctx.fillText("Click anywhere to restart", canvas.width/2, canvas.height/2 + 100);
            }

            if (gameState === 'PRE_START') {
                ctx.fillStyle = 'rgba(0, 0, 0, 0.9)'; ctx.fillRect(0, 0, canvas.width, canvas.height); ctx.fillStyle = '#e74c3c'; ctx.font = 'bold 42px "Courier New"'; ctx.textAlign = 'center'; ctx.fillText("GOTHIC SURVIVORS", canvas.width/2, canvas.height/2 - 40); ctx.fillStyle = '#f1c40f'; ctx.font = '18px "Courier New"'; ctx.fillText("Click anywhere to initialize Audio System", canvas.width/2, canvas.height/2 + 40);
            }
            else if (gameState === 'START') {
                ctx.fillStyle = 'rgba(0, 0, 0, 0.9)'; ctx.fillRect(0, 0, canvas.width, canvas.height); ctx.fillStyle = '#e74c3c'; ctx.font = 'bold 42px "Courier New"'; ctx.textAlign = 'center'; ctx.fillText("GOTHIC SURVIVORS", canvas.width/2, canvas.height/2 - 40); ctx.fillStyle = '#fff'; ctx.font = '18px "Courier New"'; ctx.fillText("WASD/Arrows to Move. Auto-attack.", canvas.width/2, canvas.height/2 + 20);
                
                let pulse = 0.5 + 0.5 * Math.sin(Date.now() * 0.005); ctx.fillStyle = `rgba(46, 204, 113, ${pulse})`; ctx.font = 'bold 20px "Courier New"'; ctx.fillText("CLICK TO BEGIN RUN", canvas.width/2, canvas.height/2 + 80);
                
                // New Load Game Button
                ctx.fillStyle = '#2c3e50'; ctx.fillRect(canvas.width/2 - 100, 360, 200, 40); ctx.strokeStyle = '#ecf0f1'; ctx.lineWidth = 2; ctx.strokeRect(canvas.width/2 - 100, 360, 200, 40);
                ctx.fillStyle = '#fff'; ctx.font = 'bold 18px "Courier New"'; ctx.fillText("LOAD GAME", canvas.width/2, 386);
            }

            update(); requestAnimationFrame(gameLoop);
        }

        requestAnimationFrame(gameLoop);

    </script>
</body>
</html>
