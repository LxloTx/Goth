                            if (gameState === 'SAVE_MENU') { saveState = 'SAVING'; savingTimer = Date.now(); playSaveSFX(); } else { loadGame(selectedSlot); }
                        }
                        if (mouseX >= midX + 20 && mouseX <= midX + 120) { saveState = 'SELECT_SLOT'; playHoverSFX(); } 
                    }
                }
                return;
            }

            if (gameState === 'PAUSED') {
                let midX = canvas.width / 2;
